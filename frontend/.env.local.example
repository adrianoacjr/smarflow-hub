# URL base do seu backend (FastAPI, Django, Spring, etc.)
VITE_API_BASE_URL=http://localhost:8000

# App ID do Meta Developer
VITE_META_APP_ID=your_meta_app_id_here

# App Secret do Meta Developer
VITE_META_APP_SECRET=your_meta_app_secret_here

# Long-lived Access Token da Graph API
VITE_META_ACCESS_TOKEN=your_long_lived_access_token_here

# Página do Instagram/Facebook que sua automação irá gerenciar
VITE_META_PAGE_ID=your_page_id_here

# Versão da Graph API (opcional, mas recomendado)
VITE_META_GRAPH_VERSION=v21.0

# Ambiente da aplicação: developent, staging, production
VITE_ENV=development
